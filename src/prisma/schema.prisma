generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  ANALYST
  VIEWER
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum RecordType {
  INCOME
  EXPENSE
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
}

enum AuditEntityType {
  USER
  FINANCIAL_RECORD
  CATEGORY
}

model User {
  id           String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String     @db.VarChar(100)
  email        String     @unique @db.VarChar(255)
  passwordHash String     @map("password_hash") @db.VarChar(255)
  role         UserRole   @default(VIEWER)
  status       UserStatus @default(ACTIVE)
  lastLoginAt  DateTime?  @map("last_login_at") @db.Timestamptz
  createdAt    DateTime   @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime   @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt    DateTime?  @map("deleted_at") @db.Timestamptz

  financialRecords FinancialRecord[]
  refreshTokens    RefreshToken[]
  auditLogs        AuditLog[]        @relation("PerformedBy")
  categories       Category[]        @relation("CategoryCreator")

  @@index([email], map: "idx_users_email")
  @@index([role, status], map: "idx_users_role_status")
  @@index([deletedAt], map: "idx_users_deleted_at")
  @@map("users")
}

model Category {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String    @unique @db.VarChar(100)
  description String?   @db.Text
  color       String?   @db.VarChar(7) // hex color e.g. #4CAF50
  icon        String?   @db.VarChar(50)
  isSystem    Boolean   @default(false) @map("is_system")
  createdBy   String?   @map("created_by") @db.Uuid // null for system categories
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz

  creator          User?             @relation("CategoryCreator", fields: [createdBy], references: [id])
  financialRecords FinancialRecord[]

  @@index([name], map: "idx_categories_name")
  @@index([isSystem], map: "idx_categories_is_system")
  @@index([deletedAt], map: "idx_categories_deleted_at")
  @@map("categories")
}

model FinancialRecord {
  id         String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String     @map("user_id") @db.Uuid
  categoryId String     @map("category_id") @db.Uuid
  amount     Decimal    @db.Decimal(15, 2)
  type       RecordType
  date       DateTime   @db.Date
  notes      String?    @db.Text
  createdAt  DateTime   @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime   @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt  DateTime?  @map("deleted_at") @db.Timestamptz

  user     User     @relation(fields: [userId], references: [id])
  category Category @relation(fields: [categoryId], references: [id])

  @@index([userId], map: "idx_fr_user_id")
  @@index([categoryId], map: "idx_fr_category_id")
  @@index([date], map: "idx_fr_date")
  @@index([type], map: "idx_fr_type")
  @@index([userId, type, date], map: "idx_fr_composite")
  @@index([deletedAt], map: "idx_fr_deleted_at")
  @@index([createdAt], map: "idx_fr_created_at")
  @@map("financial_records")
}

model RefreshToken {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  tokenHash String   @unique @map("token_hash") @db.Text // hashed before storage
  expiresAt DateTime @map("expires_at") @db.Timestamptz
  isRevoked Boolean  @default(false) @map("is_revoked")
  ipAddress String?  @map("ip_address") @db.VarChar(45) // supports IPv6
  userAgent String?  @map("user_agent") @db.Text
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id])

  @@index([userId], map: "idx_rt_user_id")
  @@index([expiresAt], map: "idx_rt_expires_at")
  @@index([isRevoked], map: "idx_rt_is_revoked")
  @@map("refresh_tokens")
}

model AuditLog {
  id          String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  entityType  AuditEntityType @map("entity_type")
  entityId    String          @map("entity_id") @db.Uuid
  action      AuditAction
  oldValues   Json?           @map("old_values") // JSONB — state before mutation
  newValues   Json?           @map("new_values") // JSONB — state after mutation
  performedBy String?         @map("performed_by") @db.Uuid // null for system actions
  ipAddress   String?         @map("ip_address") @db.VarChar(45)
  userAgent   String?         @map("user_agent") @db.Text
  createdAt   DateTime        @default(now()) @map("created_at") @db.Timestamptz

  performer User? @relation("PerformedBy", fields: [performedBy], references: [id])

  @@index([entityType, entityId], map: "idx_al_entity")
  @@index([performedBy], map: "idx_al_performed_by")
  @@index([createdAt], map: "idx_al_created_at")
  @@index([action], map: "idx_al_action")
  @@map("audit_logs")
}
